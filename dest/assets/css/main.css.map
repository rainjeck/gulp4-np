/*!
 --- HELPERS ------------------------------------
*/

.hide
  display: none


.tab
  display: none
  visibility: hidden
  opacity: 0

  &.is-active
    display: block
    visibility: visible
    animation: tab-show 0.25s linear 0.01s 1 forwards


@keyframes tab-show {
  from {
    opacity: 0
  }
  to {
    opacity: 1
  }
}


.iframe-container
  overflow: hidden
  padding-top: 56.25%
  position: relative
  width: 100%

  iframe
    border: 0
    height: 100%
    left: 0
    position: absolute
    top: 0
    width: 100%
