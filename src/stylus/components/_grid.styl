/*!
 --- GRID ---------------------
*/

gridPadding = 15px


.rw
  display: flex
  flex-direction: row
  flex-wrap: wrap
  list-style: none
  margin: 0 (-(gridPadding))


.cl
  width: 100%
  padding: 0 gridPadding


col(num, columns)
  max-width floor( ((100% / columns)* num), 2 )


grid($columns, $prefix = '')
  for $col in 1..$columns
    .cl{$prefix}-{$col}
      max-width floor( ((100% / $columns) * $col), 6 )


